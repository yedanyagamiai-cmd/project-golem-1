{
  "name": "project-golem",
  "version": "9.2.0",
  "description": "Project Golem v9.1 (Ultimate Chronos + MultiAgent Edition) - Collaborative AI System",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage --runInBand",
    "test:security": "jest tests/safeguard.test.js",
    "arch:check": "node scripts/check-architecture-boundaries.js",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "build": "cd web-dashboard && npm run build",
    "// --- 核心啟動 ---": "",
    "start": "node --expose-gc apps/runtime/index.js",
    "dashboard": "node --expose-gc apps/runtime/index.js dashboard",
    "dev": "nodemon --expose-gc apps/runtime/index.js dashboard",
    "doctor": "node scripts/doctor.js",
    "// --- 跨平台安裝指令 ---": "",
    "win:setup": "setup.bat",
    "unix:setup": "chmod +x setup.sh && ./setup.sh",
    "unix:start": "./setup.sh",
    "// --- 自動化 ---": "",
    "postinstall": "echo [INFO] Golem Core dependencies installed."
  },
  "keywords": [
    "golem",
    "ai",
    "playwright",
    "gemini",
    "neural-memory",
    "blessed",
    "chronos"
  ],
  "author": "Arvin Chen",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "0.21.0",
    "@lancedb/lancedb": "^0.26.2",
    "@xenova/transformers": "^2.17.2",
    "adm-zip": "^0.5.16",
    "apache-arrow": "^18.1.0",
    "blessed": "0.1.81",
    "blessed-contrib": "4.11.0",
    "cors": "^2.8.6",
    "discord.js": "^14.25.1",
    "dotenv": "16.4.5",
    "express": "5.2.1",
    "grammy": "^1.41.1",
    "jiti": "^2.6.1",
    "memory-lancedb-pro": "^1.1.0-beta.9",
    "opossum": "^9.0.0",
    "playwright": "^1.42.1",
    "socket.io": "4.8.3",
    "socket.io-client": "4.8.3",
    "sqlite3": "^6.0.1",
    "uuid": "9.0.1"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "3.0.2"
  },
  "overrides": {
    "undici": "^6.24.1",
    "xml2js": "^0.6.2"
  },
  "engines": {
    "node": ">=20 <23"
  }
}