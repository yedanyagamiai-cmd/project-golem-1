
# ======================================================
# 🧠 Golem Brain (Web Gemini 大腦設定)
# ======================================================
# Gemini Web URLs (高可用備用網址)
# 說明：支援多組網址輪替，若第一組失效則自動使用後續網址。以半形逗號 "," 分隔。
# 預設：https://gemini.google.com/app,https://gemini.google.com/app?hl=zh-TW
GEMINI_URLS=https://gemini.google.com/app,https://gemini.google.com/app?hl=zh-TW

# ======================================================
# 💬 Messaging Platforms (通訊平台設定)
# ======================================================
# Telegram 引擎模式 (grammy | legacy)
# 說明：設定底層通訊架構。推薦使用具備斷路器與防呆機制的 grammy，若遇到相容性狀況可降級回 legacy。
# 預設：預設會自動偵測，通常為 grammy。
TG_ENGINE=grammy

# Telegram Circuit Breaker 斷路器設定 (進階)
# 說明：保護輪詢機制，當網路異常時自動斷開避免連線風暴。
CB_TG_TIMEOUT_MS=10000
CB_TG_RESET_MS=15000
CB_TG_ERROR_PCT=30

# Telegram Bot Token
# 說明：從 @BotFather 取得。
TELEGRAM_TOKEN=

# Telegram 驗證模式 (ADMIN | CHAT)
# ADMIN: 僅回應管理員。
# CHAT: 回應群組內所有人。
TG_AUTH_MODE=ADMIN

# Telegram 管理員與群組 ID
ADMIN_ID=
TG_CHAT_ID=

# Discord Bot Token
# 說明：從 Discord Developer Portal 取得。
DISCORD_TOKEN=
DISCORD_ADMIN_ID=

# ======================================================
# ⚙️ System Config (系統進階設定)
# ======================================================
# 🎭 Playwright Profile (多 Profile 支援)
# 說明：設定此變數可讓您切換不同的瀏覽器環境 (Session/Cookies/Skills)。
# 預設：若不填則為空，系統將回退使用 ./golem_memory。
# 建議：填入簡單的英文代號，例如: default, work, personal
PLAYWRIGHT_PROFILE=

# 瀏覽器資料暫存路徑 (進階)
# 說明：存放瀏覽器 Session，若設定此項則會覆蓋 PLAYWRIGHT_PROFILE 的預設路徑。
# 預設：空值 (由 PLAYWRIGHT_PROFILE 決定)
USER_DATA_DIR=

# 測試模式 (通常設為 false)
# true: 只測試程式碼是否能執行，不啟動瀏覽器。
# false: 正常啟動。

GOLEM_TEST_MODE=false

# 👻 無頭模式 (可選，預設不填或 false)
# 說明：設定為 true 會讓 Playwright 瀏覽器完全在背景隱形執行 (不跳出視窗)。
# ⚠️ 注意：首次使用 Gemini 必須登入 Google 帳號與解開 CAPTCHA，因此第一次啟動請把此處留空。
# 等確定已經有 `golem_memory` 的登入紀錄後，再設定為 true 來達到最舒適的體驗。

PLAYWRIGHT_HEADLESS=

# 🕵️ Playwright Anti-Detection (純 Playwright 反偵測)
# 說明：預設啟用，會注入基礎指紋偽裝（webdriver、languages、platform、plugins、WebGL）。
PLAYWRIGHT_STEALTH_ENABLED=true
# 說明：瀏覽器語系優先順序，逗號分隔。
PLAYWRIGHT_STEALTH_LANGUAGES=zh-TW,zh,en-US,en
PLAYWRIGHT_STEALTH_LOCALE=zh-TW
PLAYWRIGHT_STEALTH_TIMEZONE=Asia/Taipei
# 說明：留空時依作業系統自動推導（MacIntel / Win32 / Linux x86_64）。
PLAYWRIGHT_STEALTH_PLATFORM=
# 說明：留空時自動生成接近真實 Chrome 的 UA 字串。
PLAYWRIGHT_STEALTH_USER_AGENT=
PLAYWRIGHT_STEALTH_HARDWARE_CONCURRENCY=8
PLAYWRIGHT_STEALTH_DEVICE_MEMORY=8
PLAYWRIGHT_STEALTH_WEBGL_VENDOR=Intel Inc.
PLAYWRIGHT_STEALTH_WEBGL_RENDERER=Intel Iris OpenGL Engine
# true: 每次啟動隨機桌面常見解析度；false: 固定 1366x768
PLAYWRIGHT_STEALTH_RANDOM_VIEWPORT=true
# 可指定固定解析度，例如 1366x768（留空則依上面設定）
PLAYWRIGHT_STEALTH_VIEWPORT=
# 進階：若本機有安裝 Chrome，可填入 chrome/chrome-beta/chrome-dev
PLAYWRIGHT_BROWSER_CHANNEL=

# 部署模式 (固定為 SINGLE)
# SINGLE: 單機模式，使用單一組 Telegram/Discord 設定。

GOLEM_MODE=SINGLE

# Web Dashboard 埠號 (預設 3000)
DASHBOARD_PORT=3000

# 控制台啟用開關 (true | false)
ENABLE_WEB_DASHBOARD=true

# 系統初次初始化標記
SYSTEM_CONFIGURED=false

# Dashboard 開發模式 (true | false)
# 說明：設為 true 可跳過 npm run build，使用 Next.js 開發伺服器。
DASHBOARD_DEV_MODE=false

# AI 興趣偏好 (逗號隔開)
# 說明：用於自主行動（如發送新聞、主動閒聊）時的選題參考。
# 預設：科技圈熱門話題,全球趣聞
USER_INTERESTS=科技圈熱門話題,全球趣聞

# ======================================================
# ⏳ Automated Schedule (自動化作息設定)
# ======================================================
# 喚醒間隔 (最小、最大) - 單位：分鐘
# 說明：在此區間內隨機安排下次醒來的時間。
# 限制：最小 1，最大 10080 (一週)。
GOLEM_AWAKE_INTERVAL_MIN=10
GOLEM_AWAKE_INTERVAL_MAX=60

# 夜間休眠設定
# 格式：HH 或 HH:mm (24小時制)
# 說明：在此時段內 Golem 會進入休眠，不會主動發起對話。
GOLEM_SLEEP_START=23:00
GOLEM_SLEEP_END=07:00

# ======================================================
# 🧠 Memory Engine (記憶引擎設定)
# ======================================================
# 記憶引擎模式: lancedb-pro (建議), lancedb-legacy (舊版), native (系統原生), system (系統原生)
GOLEM_MEMORY_MODE=lancedb-pro

# ======================================================
# ☁️ OTA Update Config (空中升級設定)
# ======================================================
# 指定 /update 指令抓取原始碼的 GitHub 儲存庫
# 預設若留空則使用：https://raw.githubusercontent.com/Arvincreator/project-golem/main/

GITHUB_REPO=

# ======================================================
# 🦞 Moltbook Social Network (AI 社交網絡)
# ======================================================
# Moltbook API Key (核心憑證)
# 取得方式：啟動 Golem 後，對他說「去註冊 Moltbook」。

MOLTBOOK_API_KEY=

MOLTBOOK_AGENT_NAME=

PLAYWRIGHT_REMOTE_DEBUGGING_PORT=9222

ENABLE_LOG_NOTIFICATIONS=false

# ======================================================
# 🌐 Remote Access (遠端連線設定)
# ======================================================
# 是否允許從區域網路或外部 IP 連線 Dashboard。
# true  - 開放所有來源（適合遠端或 LAN 連線）
# false - 僅限本機 localhost 連線（預設，較安全）
# ⚠️ 若設為 true，請確保已有防火牆或 VPN 保護。

ALLOW_REMOTE_ACCESS=false

# ======================================================
# 🛠️ System Maintenance (系統維護與自動化)
# ======================================================
# 核心引擎 (gemini | ollama)
# gemini: Browser-in-the-Loop (Playwright + Web Gemini)
# ollama: 本地/私有部署 LLM API
GOLEM_BACKEND=gemini

# --- Ollama (Brain / Embedding / Rerank) ---
# Base URL 範例: http://127.0.0.1:11434
GOLEM_OLLAMA_BASE_URL=http://127.0.0.1:11434
# 大腦模型（GOLEM_BACKEND=ollama 時生效）
GOLEM_OLLAMA_BRAIN_MODEL=
# 嵌入模型（GOLEM_EMBEDDING_PROVIDER=ollama 時生效）
GOLEM_OLLAMA_EMBEDDING_MODEL=
# Rerank 模型（選填；留空則不做二次重排）
GOLEM_OLLAMA_RERANK_MODEL=
# Ollama HTTP 逾時（毫秒）
GOLEM_OLLAMA_TIMEOUT_MS=60000

# --- Command Security (指令安全設定) ---
# 是否在初始階段攔截危險操作 (如 rm -rf)
GOLEM_STRICT_SAFEGUARD=false
# 是否自動放行系統安全庫指令 (如 ls, cat, grep) 而不需核准
GOLEM_TRUST_SYSTEM_COMMANDS=false
# 是否完全自動放行所有指令 (極危險，核心阻斷除外)
GOLEM_AUTO_APPROVE_ALL=false
# 當全自動模式開啟時，是否隱藏中間過程 (沈默執行)
GOLEM_SILENT_AUTO_APPROVE=false

# 日誌自動檢查與歸檔 (單位：分鐘)
ARCHIVE_CHECK_INTERVAL=30
ARCHIVE_THRESHOLD_YESTERDAY=5
ARCHIVE_THRESHOLD_TODAY=20

# 支援的語言模型 (Embedding)
# provider: local | ollama
GOLEM_EMBEDDING_PROVIDER=local
GOLEM_LOCAL_EMBEDDING_MODEL=Xenova/bge-small-zh-v1.5

# ======================================================
# 📓 NotebookLM (Google NotebookLM 整合)
# ======================================================
# 說明：存放 Google 登入 Cookies 的 JSON 字串。
# 取得方式：執行 `notebooklm login` 後，將 ~/.notebooklm/storage_state.json 內容貼到此處。
NOTEBOOKLM_AUTH_JSON=
